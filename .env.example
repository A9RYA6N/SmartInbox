# SmartInbox – Environment Configuration
# Copy this file to .env and fill in your values.

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="SmartInbox – SMS Spam Detection API"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development

# ── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/smartinbox

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_32_CHAR_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── ML ───────────────────────────────────────────────────────────────────────
MODEL_VERSION=v2

# ── Admin Setup ───────────────────────────────────────────────────────────────
# Secret key to register as admin via the /register endpoint
ADMIN_SETUP_KEY=SmartInbox@Admin2026

# ── CORS ─────────────────────────────────────────────────────────────────────
# JSON list of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/api.log
